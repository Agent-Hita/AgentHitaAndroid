<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Checked: mint thumb pops against the cyan card and purple track -->
    <item android:state_checked="true"  android:color="@color/hita_mint" />
    <!-- Unchecked: muted light-blue so it reads as "off" -->
    <item android:state_checked="false" android:color="@color/hita_text_secondary" />
</selector>
