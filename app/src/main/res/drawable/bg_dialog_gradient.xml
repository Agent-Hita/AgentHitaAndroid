<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Dark navy-to-purple diagonal base -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D2142"
                android:centerColor="#111540"
                android:endColor="#1A0F3E"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Subtle cyan border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#336AC6FF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</layer-list>
