<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/hita_surface"
        app:title=""
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Dark">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="Agent Hita"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agent Hita"
                android:textColor="@color/hita_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Status strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Protecting you from harmful digital influence — privately."
            android:textSize="12sp"
            android:textColor="@color/hita_text_secondary"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.02"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:id="@+id/view_status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/shape_status_dot" />

            <TextView
                android:id="@+id/tv_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monitoring is active"
                android:textSize="13sp"
                android:textColor="@color/hita_text_primary" />

        </LinearLayout>

        <!-- AI status chip — tapping opens GemmaDownloadActivity -->
        <LinearLayout
            android:id="@+id/layout_ai_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_ai_card"
            android:paddingStart="10dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_ai_spark"
                android:contentDescription="AI"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_ai_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Private AI Model: Download"
                android:textSize="12sp"
                android:textColor="@color/hita_primary" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorControlHighlight" />

    <!-- Alert summary count -->
    <TextView
        android:id="@+id/tv_event_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp"
        android:text="No alerts detected yet."
        android:textSize="13sp"
        android:textAllCaps="true"
        android:letterSpacing="0.06"
        android:textColor="@color/hita_text_secondary" />

    <!-- Date filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingBottom="4dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_date_all"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All time"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_date_today"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_date_week"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This week" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_date_month"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This month" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Category filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cat_all"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All types"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cat_sextortion"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sexual manipulation" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cat_financial"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Financial scam" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cat_grooming"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grooming" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cat_romance"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Romance scam" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cat_phishing"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phishing" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cat_luring"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Luring" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cat_harassment"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harassment" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Scrollable events list — fills remaining screen space -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_recent_events"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>
