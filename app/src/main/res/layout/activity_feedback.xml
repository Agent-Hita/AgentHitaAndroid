<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/hita_surface"
        app:title="Feedback"
        app:titleTextColor="@color/hita_text_primary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/hita_text_primary"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Website link -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visit us on our website for more information"
                android:textSize="14sp"
                android:textColor="@color/hita_text_secondary"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_website"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="www.agenthita.org"
                android:textSize="14sp"
                android:textColor="@color/hita_primary"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp"
                android:paddingVertical="8dp" />

            <!-- Rating section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How would you rate Agent Hita?"
                android:textSize="16sp"
                android:textColor="@color/hita_text_primary"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp" />

            <RatingBar
                android:id="@+id/rating_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:numStars="5"
                android:stepSize="1"
                android:rating="0"
                android:layout_marginBottom="28dp" />

            <!-- Feedback text -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="What would you like to see improved? (optional)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_feedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="4"
                    android:maxLines="8"
                    android:gravity="top" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Submit button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submit Feedback"
                android:layout_marginBottom="16dp" />

            <!-- Success message -->
            <LinearLayout
                android:id="@+id/layout_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓  Thank you for your feedback!"
                    android:textSize="15sp"
                    android:textColor="@color/hita_mint"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
