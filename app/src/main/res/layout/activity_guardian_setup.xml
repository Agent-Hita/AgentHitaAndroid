<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/hita_surface"
        app:title="Guardian Alerts"
        app:titleTextColor="@color/hita_text_primary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/hita_text_primary"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Optionally set up a trusted contact to receive minimal alerts if a high-risk pattern is detected. They will NOT see your messages — only the type of threat and its severity."
                android:textSize="14sp"
                android:textColor="@color/hita_text_secondary"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="12dp" />

            <!-- Age of the protected person — adjusts detection sensitivity -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/hita_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Who are you protecting?"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/hita_primary"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Selecting an age group lowers detection thresholds so threats are flagged earlier for younger users."
                        android:textSize="12sp"
                        android:textColor="@color/hita_text_secondary"
                        android:lineSpacingMultiplier="1.3"
                        android:layout_marginBottom="12dp" />

                    <RadioGroup
                        android:id="@+id/rg_user_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rb_self"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Myself (adult)"
                            android:textColor="@color/hita_text_primary"
                            android:textSize="14sp"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rb_vulnerable_adult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Vulnerable adult"
                            android:textColor="@color/hita_text_primary"
                            android:textSize="14sp" />

                        <RadioButton
                            android:id="@+id/rb_under_21"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Adolescent (13–21)"
                            android:textColor="@color/hita_text_primary"
                            android:textSize="14sp" />

                        <RadioButton
                            android:id="@+id/rb_under_13"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Child (under 13)"
                            android:textColor="@color/hita_text_primary"
                            android:textSize="14sp" />

                    </RadioGroup>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Their name (optional)"
                        android:layout_marginTop="14dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_monitored_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Used to identify who sent a flagged message in the threat log — helpful when monitoring multiple people."
                        android:textSize="11sp"
                        android:textColor="@color/hita_text_secondary"
                        android:lineSpacingMultiplier="1.3"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Guardian alerts toggle — prominent card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/hita_primary"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_alerts_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Guardian alerts (OFF)"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notify a trusted contact on high-risk detections"
                            android:textSize="12sp"
                            android:textColor="#CCffffff"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_alerts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Guardian email address"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="32dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_guardian_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save and Continue"
                android:layout_marginBottom="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_skip"
                style="@style/Widget.AgentHita.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Skip for now" />

            <!-- What triggers an alert — moved below Skip so it doesn't block the CTA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="@color/hita_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="When is an alert sent?"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/hita_primary"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"
                            android:text="•"
                            android:textColor="@color/hita_accent"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Agent Hita detects a HIGH-risk pattern in a message you receive"
                            android:textColor="@color/hita_text_primary"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"
                            android:text="•"
                            android:textColor="@color/hita_accent"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="The threat category (e.g. sextortion, financial scam) and risk level are included"
                            android:textColor="@color/hita_text_primary"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"
                            android:text="•"
                            android:textColor="@color/hita_accent"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="The time and app the message came from are included"
                            android:textColor="@color/hita_text_primary"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/hita_background"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"
                            android:text="✗"
                            android:textColor="@color/hita_danger"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Your guardian will NEVER see your message content or the sender's identity"
                            android:textColor="@color/hita_text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
