<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/hita_surface"
        app:title=""
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Dark">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="Agent Hita"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agent Hita"
                android:textColor="@color/hita_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your on-device safety guardian"
                android:textSize="16sp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Agent Hita watches for harmful patterns in your messages — things like manipulation, threats, or scam pressure — and warns you privately on your device.\n\nAll analysis happens on your phone. Nothing is sent to the cloud."
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Agent Hita needs permission to read your notifications to do this. You can revoke this permission at any time in Settings."
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="40dp"
                android:alpha="0.7" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_grant_permission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant Accessibility Access"
                android:layout_marginBottom="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_continue"
                style="@style/Widget.AgentHita.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="I've granted access — Continue"
                android:enabled="false" />

            <TextView
                android:id="@+id/tv_permission_warning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please grant accessibility access to continue."
                android:textColor="#EF4444"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
