<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/hita_surface"
        app:title=""
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Dark">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="Agent Hita"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agent Hita"
                android:textColor="@color/hita_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="top|center_horizontal">

            <!-- Prominent disclosure — required by Google Play Accessibility API policy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dialog_gradient"
                android:padding="20dp"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Accessibility permission — how it is used"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/hita_primary"
                    android:layout_marginBottom="4dp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/hita_primary"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Agent Hita uses Android's Accessibility permission to read message text displayed on screen by:"
                    android:textSize="13sp"
                    android:textColor="@color/hita_text_primary"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp · Instagram · Google Messages · Samsung Messages · SMS apps"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/hita_text_primary"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Why this permission is needed"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/hita_text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This is the only way Agent Hita can check messages in real time without sending them to a server. It reads text that is already on your screen — the same text you are looking at. It cannot see messages when the app is in the background or access your stored chat history."
                    android:textSize="13sp"
                    android:textColor="@color/hita_text_secondary"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What this enables"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/hita_text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Detection of grooming, financial scams, romance scams, identity phishing, sextortion, and harassment\n• Private on-device alerts when harmful patterns are detected\n• Optional alert to a trusted guardian contact"
                    android:textSize="13sp"
                    android:textColor="@color/hita_text_secondary"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Message text is analysed instantly on your device and never saved or sent anywhere. You can turn this off at any time in Settings → Accessibility → Agent Hita."
                    android:textSize="12sp"
                    android:textColor="@color/hita_text_secondary"
                    android:lineSpacingMultiplier="1.5"
                    android:alpha="0.8" />

            </LinearLayout>

            <!-- Inoculation: name Android's system warning before the user sees it,
                 so it reads as expected rather than alarming -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dialog_gradient"
                android:padding="20dp"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Heads up: Android will show a strong warning next"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/hita_accent"
                    android:layout_marginBottom="4dp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/hita_accent"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Android will tell you Agent Hita can &#8220;read all screen content.&#8221; It&#8217;s accurate — reading the screen is literally how protection works.\n\nHere&#8217;s what we never do: store, transmit, or share what it sees."
                    android:textSize="13sp"
                    android:textColor="@color/hita_text_primary"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tv_view_source_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don&#8217;t take our word for it — review our source code"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/hita_accent"
                    android:padding="4dp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_grant_permission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant Accessibility Access"
                android:layout_marginBottom="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_continue"
                style="@style/Widget.AgentHita.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="I've granted access — Continue"
                android:enabled="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_decline"
                style="@style/Widget.AgentHita.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Decline" />

            <TextView
                android:id="@+id/tv_permission_warning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please grant accessibility access to continue."
                android:textColor="#EF4444"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
