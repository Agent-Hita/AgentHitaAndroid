<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_gradient"
    android:padding="28dp">

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_ai_spark"
        app:tint="@color/hita_accent" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Private AI Analysis"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/hita_text_primary"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/hita_accent"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Agent Hita uses Google&#8217;s Gemma model to analyse messages on your device. The model (~950 MB) is downloaded once and stored privately on your phone &#8212; it never leaves your device.\n\nScroll through the full Gemma Terms of Use below before downloading."
        android:textSize="14sp"
        android:textColor="@color/hita_text_secondary"
        android:lineSpacingMultiplier="1.5"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:id="@+id/scroll_terms"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_terms_scroll"
        android:padding="12dp"
        android:clipToPadding="false"
        android:scrollbarStyle="insideOverlay"
        android:fadeScrollbars="false">

        <TextView
            android:id="@+id/tv_terms_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/hita_text_secondary"
            android:lineSpacingMultiplier="1.5" />

    </ScrollView>

    <TextView
        android:id="@+id/tv_scroll_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#8595; Scroll to read all terms"
        android:textSize="12sp"
        android:textColor="@color/hita_accent"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_accept_download"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Accept Terms &amp; Download"
        android:enabled="false"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_not_now"
        style="@style/Widget.AgentHita.Button.Text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Not Now" />

</LinearLayout>
