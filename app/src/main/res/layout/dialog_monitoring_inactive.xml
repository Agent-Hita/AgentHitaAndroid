<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_gradient"
    android:padding="28dp">

    <!-- Shield icon -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_hita_shield"
        app:tint="@color/hita_primary" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Monitoring is not active"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/hita_text_primary"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Divider with cyan tinge -->
    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/hita_primary"
        android:layout_marginBottom="16dp" />

    <!-- Message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Agent Hita needs the Accessibility permission to monitor conversations for harmful content.\n\nTap Enable to open Accessibility Settings, then find Agent Hita Safety Monitor and turn it on."
        android:textSize="14sp"
        android:textColor="@color/hita_text_secondary"
        android:lineSpacingMultiplier="1.5"
        android:gravity="center"
        android:layout_marginBottom="28dp" />

    <!-- Enable button — gradient -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_enable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable"
        android:layout_marginBottom="8dp" />

    <!-- Not now button — text style -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_not_now"
        style="@style/Widget.AgentHita.Button.Text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Not now" />

</LinearLayout>
