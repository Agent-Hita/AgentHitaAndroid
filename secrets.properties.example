# Copy this file to secrets.properties and fill in real values.
# secrets.properties is gitignored — never commit real keys.
# In CI, secrets.properties is checked out from the private AgentHitaAndroidConfig repo.

FEEDBACK_API_KEY=your-api-key-here
FEEDBACK_API_URL=https://api.agenthita.org/feedback
